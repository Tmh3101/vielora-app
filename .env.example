# ChatBot Builder Pro - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# APP CONFIGURATION
# ===========================================
NODE_ENV=development # Set to 'production' in production environment

NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_DEMO_BOT_ID=vielora_demo_bot_id

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Get these from your Supabase project settings
# NOTE: NEXT_PUBLIC_ prefix makes variables available on client-side
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side only (for API routes) - KEEP THIS SECRET!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# This is used for PostgreSQL connection (e.g., for Shopify session storage)
DATABASE_URL=your_postgresql_connection_string

# ===========================================
# GOOGLE GEMINI AI CONFIGURATION
# ===========================================
# Get your API key from: https://aistudio.google.com/app/apikey
# Free Tier includes: 15 RPM for embedding, 15 RPM for chat
GOOGLE_API_KEY=your_google_api_key

# Model configurations (recommended defaults)
EMBEDDING_MODEL=gemini-embedding-001
CHAT_MODEL=gemini-2.5-flash-lite

# ===========================================
# REDIS CONFIGURATION (Required for Async Crawler)
# ===========================================
# Option 1: Upstash Redis (Recommended for serverless)
# UPSTASH_REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Option 2: Self-hosted Redis (Docker)
REDIS_PASSWORD=your_redis_password
REDIS_IP=0.0.0.0
REDIS_PORT=50379

# ===========================================
# RESEND CONFIGURATION (For transactional emails)
# Get your API key from: https://resend.com/dashboard/api-keys
# ===========================================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL="YourApp <example@yourapp.com>"

# ===========================================
# PAYOS CONFIGURATION (For Payment Integration)
# ===========================================
# Get these from your PayOS dashboard: https://dashboard.payos.vn/api-keys
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_TEST_MODE=true # Set to false in production

# ===========================================
# SHOPIFY CONFIGURATION (For Shopify App Integration)
# ===========================================
# Get these from your Shopify Partner Dashboard when you create an app
NEXT_PUBLIC_SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret