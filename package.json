    "dev": "concurrently -n next,worker,cron -c blue,green,yellow \"next dev\" \"npm run worker\" \"npm run cron\"",
    "dev:next": "next dev",
    "dev:worker": "tsx watch scripts/start-worker.ts",
    "dev:cron": "tsx watch scripts/start-cron.ts",
    "build": "next build",
    "start": "next start",
    "start:all": "concurrently -n next,worker,cron -c blue,green,yellow \"next start\" \"npm run worker\" \"npm run cron\"",
    "lint": "next lint",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "tsx scripts/start-worker.ts",
    "cron": "tsx scripts/start-cron.ts",
    "worker:build": "tsc scripts/start-worker.ts --outDir dist/scripts --esModuleInterop --skipLibCheck",
